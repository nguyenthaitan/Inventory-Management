# Node Environment (development, production, test)
NODE_ENV=development

# Server Port
PORT=3000

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/inventory

# Frontend Origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# ─── Keycloak ───────────────────────────────────────────────────────────────
# URL server Keycloak (không có trailing slash)
KEYCLOAK_SERVER_URL=http://localhost:8080
#KEYCLOAK_SERVER_URL=http://inventory_keycloak:8080

# Tên realm đã tạo trong Keycloak
KEYCLOAK_REALM=inventory

# Client ID của backend app (Confidential client, có client secret)
KEYCLOAK_CLIENT_ID=inventory-backend

# Client Secret của inventory-backend client
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# Admin CLI client (dùng để gọi Admin REST API)
# Dùng service account của inventory-backend hoặc admin-cli riêng
KEYCLOAK_ADMIN_CLIENT_ID=inventory-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-in-production

## Địa chỉ các broker Kafka, phân cách bằng dấu phẩy nếu nhiều broker
KAFKA_BROKERS=localhost:9092
## Client ID dùng để kết nối Kafka
KAFKA_CLIENT_ID=inventory-app

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-72B-Instruct
HUGGINGFACE_API_URL=https://router.huggingface.co/v1/chat/completions