{
  "realm": "inventory",
  "displayName": "Inventory Management System",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "refreshTokenMaxReuse": 0,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "Manager",
        "description": "Quản lý kho — toàn quyền đọc/ghi, phê duyệt phiếu, báo cáo"
      },
      {
        "name": "Operator",
        "description": "Nhân viên kho — nhập/xuất kho, kiểm kê"
      },
      {
        "name": "Quality Control Technician",
        "description": "Kỹ thuật viên QC — kiểm định lô hàng, re-test, truy vết"
      },
      {
        "name": "IT Administrator",
        "description": "Quản trị hệ thống — user management, backup, logs"
      }
    ]
  },
  "clients": [
    {
      "clientId": "inventory-backend",
      "name": "Inventory Backend API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-in-production",
      "redirectUris": ["http://localhost:3001/*"],
      "webOrigins": ["http://localhost:3001", "http://localhost:3000"],
      "bearerOnly": false,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "inventory-frontend",
      "name": "Inventory Frontend SPA",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:80/*"
      ],
      "webOrigins": ["http://localhost:3000", "http://localhost:80"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    }
  ],
  "defaultDefaultClientScopes": ["web-origins", "profile", "roles", "email"],
  "users": [
    {
      "username": "admin_manager",
      "email": "manager@inventory.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Admin@123456", "temporary": false }],
      "realmRoles": ["Manager"]
    },
    {
      "username": "admin_qc",
      "email": "qc@inventory.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Admin@123456", "temporary": false }],
      "realmRoles": ["Quality Control Technician"]
    },
    {
      "username": "admin_operator",
      "email": "operator@inventory.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Admin@123456", "temporary": false }],
      "realmRoles": ["Operator"]
    },
    {
      "username": "admin_it",
      "email": "it@inventory.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Admin@123456", "temporary": false }],
      "realmRoles": ["IT Administrator"]
    }
  ]
}
